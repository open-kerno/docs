ldVectors":[],"invertedIndex":[],"pipeline":["stemmer"]}},{"documents":[{"i":4,"t":"We started this blog to share what we learn as we build Kerno. We will write about technical decisions, tools we use, and problems we solve. Some posts will be short. Others will go deep into a specific topic. We are a small team moving fast. Not every decision we make is perfect, but we try to be thoughtful about the things that are hard to change later — like data formats, API contracts, and system boundaries.","s":"Welcome to the Kerno Engineering Blog","u":"/docs/blog/welcome-to-the-eng-blog","h":"","p":3},{"i":6,"t":"Engineering standards — How we handle data, naming, and consistency across services. Incident reviews — What broke, why, and what we changed. Tool evaluations — What we tried, what we kept, and what we dropped.","s":"What to expect","u":"/docs/blog/welcome-to-the-eng-blog","h":"#what-to-expect","p":3},{"i":8,"t":"Anyone on the engineering team can publish here. Posts go through a light review before they are published. The goal is to share real context, not polished marketing content. If you are on the team and want to write something, open a PR against this repo. That is it for now. More posts coming soon.","s":"Who writes here","u":"/docs/blog/welcome-to-the-eng-blog","h":"#who-writes-here","p":3}],"index":{"version":"2.3.9","fields":["t"],"fieldVectors":[["t/4",[0,0.868,1,0.868,2,0.416,3,0.868,4,0.868,5,0.868,6,0.416,7,0.868,8,1.238,9,0.416,10,0.868,11,0.868,12,0.868,13,0.416,14,0.868,15,0.868,16,0.416,17,0.868,18,0.868,19,0.868,20,0.868,21,0.416,22,0.868,23,0.868,24,0.868,25,0.868,26,0.416,27,0.868,28,0.868,29,0.868,30,0.416,31,0.868,32,0.416,33,0.416,34,0.868,35,0.868,36,0.868,37,0.868,38,0.868]],["t/6",[9,0.555,26,0.555,30,0.555,32,0.803,33,0.555,39,0.555,40,1.158,41,1.158,42,1.158,43,1.158,44,1.158,45,1.158,46,0.555,47,1.158,48,1.158,49,1.158,50,1.158]],["t/8",[2,0.46,6,0.46,13,0.636,16,0.46,21,0.636,39,0.46,46,0.46,51,0.959,52,1.328,53,0.959,54,0.959,55,0.95